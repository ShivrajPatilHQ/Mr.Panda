# Mr. Panda backend — copy to Coolify's environment (all values stay on the server)

# Mongo Atlas connection string (from Atlas -> Connect -> Drivers)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=mrpanda

# The HOSTED Gemini key — this is YOUR key that all free usage runs on
GEMINI_API_KEY=your-hosted-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# Free tier + wallet protection
FREE_DAILY_LIMIT=5
GLOBAL_DAILY_CAP=5000
DAY_TZ=Asia/Kolkata

# A long random string the app also carries (light gate against random abuse)
APP_TOKEN=change-me-to-a-long-random-string

# A different long random string only you know (for the /v1/admin/* endpoints)
ADMIN_TOKEN=change-me-too

# Email for the passwordless restore code. Leave RESEND_API_KEY blank in dev and
# the code prints to the server logs; set it (resend.com) to send real email.
RESEND_API_KEY=
EMAIL_FROM=Mr. Panda <onboarding@resend.dev>

PORT=8080
