{
  "name": "panda-assistant",
  "version": "1.1.0",
  "description": "Mr. Panda — a corporate desktop assistant that helps with research, investor finding, and data collection.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "author": "Raj",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "mammoth": "^1.12.0"
  },
  "build": {
    "appId": "com.raj.mrpanda",
    "productName": "Mr Panda",
    "files": [
      "**/*",
      "!.npm-cache/**",
      "!dist/**",
      "!*.log",
      "!.git/**"
    ],
    "mac": {
      "target": "dir",
      "identity": null,
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    }
  }
}
